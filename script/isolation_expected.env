# isolation_expected.rc — EXPECTED process patterns for isolation_report.sh
#
# Threads matching these patterns are EXPECTED on isolated cores.
# They are the workload you intentionally pinned there (DPDK lcores,
# MTL sessions, your application threads, idle, etc.).
#
# FORMAT:
#   One bash-extended-regex pattern per line, matched against the
#   thread's "comm" field (the 16-char kernel task name).
#   Lines starting with '#' and blank lines are ignored.
#
# REGEX QUICK REFERENCE (bash =~ extended regex):
#   ^           match start of string
#   $           match end of string
#   .           any single character
#   *           zero or more of the previous
#   +           one or more of the previous
#   ?           zero or one of the previous
#   [abc]       character class (a, b, or c)
#   [^abc]      negated class (not a, b, or c)
#   (a|b)       alternation (a or b)
#   \.  \-      literal dot / hyphen (escape special chars)
#
# EXAMPLES:
#   ^myapp$           exact match "myapp"
#   ^myapp-worker     starts with "myapp-worker" (any suffix)
#   ^(foo|bar)_       starts with "foo_" or "bar_"
#
# Add your own application thread patterns below.

# --- DPDK threads ---
^eal-intr-thread$
^lcore-worker-
^dpdk-worker

# --- MTL internal threads ---
^mtl_
^tx_st
^rx_st

# --- Kernel idle / spawner (always present) ---
^swapper/
^kthread$
