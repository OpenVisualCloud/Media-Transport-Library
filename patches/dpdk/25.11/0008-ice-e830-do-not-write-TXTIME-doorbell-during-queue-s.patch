From 0000000000000000000000000000000000000001 Mon Sep 17 00:00:00 2001
From: "Kasiewicz, Marek" <marek.kasiewicz@intel.com>
Date: Thu, 8 May 2025 06:30:00 +0000
Subject: [PATCH 08/10] ice: e830: do not write TXTIME doorbell during queue
 start

Disable any stale TXTIME queue context from a previous driver (e.g.
kernel ice) BEFORE programming a new one. Move TXTIME doorbell
register assignment to after successful AQ call, and do not write 0
to the doorbell — this avoids MDD event 29.

Signed-off-by: Kasiewicz, Marek <marek.kasiewicz@intel.com>
---
 drivers/net/intel/ice/ice_rxtx.c | 21 ++++++++++++++-------
 1 file changed, 14 insertions(+), 7 deletions(-)

diff --git a/drivers/net/intel/ice/ice_rxtx.c b/drivers/net/intel/ice/ice_rxtx.c
--- a/drivers/net/intel/ice/ice_rxtx.c
+++ b/drivers/net/intel/ice/ice_rxtx.c
@@ -890,17 +890,21 @@
 		struct ice_txtime_ctx txtime_ctx = { 0 };
 		u8 ts_buf_len = ice_struct_size(ts_elem, txtimeqs, 1);
 
+		/* Disable any stale TXTIME queue context from a previous
+		 * driver (e.g. kernel ice) BEFORE programming a new one.
+		 */
+		{
+			struct ice_aqc_ena_dis_txtime_qgrp dis_buf = { 0 };
+			ice_aq_ena_dis_txtimeq(hw, txq->reg_idx, 1, false,
+					       &dis_buf, NULL);
+		}
+
 		ts_elem = ice_malloc(hw, ts_buf_len);
 		ice_setup_txtime_ctx(txq, &txtime_ctx, true);
 		ice_set_ctx(hw, (u8 *)&txtime_ctx,
 				ts_elem->txtimeqs[0].txtime_ctx,
 				ice_txtime_ctx_info);
 
-		txq->qtx_tail = hw->hw_addr + E830_GLQTX_TXTIME_DBELL_LSB(txq->reg_idx);
-
-		/* Init the Tx time tail register*/
-		ICE_PCI_REG_WRITE(txq->qtx_tail, 0);
-
 		err = ice_aq_set_txtimeq(hw, txq->reg_idx, 1, ts_elem, ts_buf_len, NULL);
 		rte_free(ts_elem);
 		if (err) {
@@ -908,6 +912,9 @@
 			rte_free(txq_elem);
 			return err;
 		}
+
+		txq->qtx_tail = hw->hw_addr + E830_GLQTX_TXTIME_DBELL_LSB(txq->reg_idx);
+		/* Do NOT write 0 to the TXTIME doorbell during init. */
 	} else {
 		txq->qtx_tail = hw->hw_addr + QTX_COMM_DBELL(txq->reg_idx);
 
--
