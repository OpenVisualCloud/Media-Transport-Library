+    inline void DiscreteFlowData::openGrainPool(char const* poolFilePath, std::size_t count, std::size_t grainPayloadSize)
+    {
+        // Stride = GrainHeader (8192) + payload — same layout as individual grain files
+        _poolGrainStride = sizeof(Grain) + grainPayloadSize;  // Grain is just { GrainHeader header; }
+
+        // Total pool size: count × stride
+        // But when opening (not creating), grainPayloadSize may be 0 — derive from file
+        auto const mode = this->created() ? AccessMode::CREATE_READ_WRITE : this->accessMode();
+        auto const totalSize = (mode == AccessMode::CREATE_READ_WRITE)
+                                   ? count * _poolGrainStride
+                                   : std::size_t{0};  // let SharedMemorySegment use file size
+
+        _pool = SharedMemorySegment{poolFilePath, mode, totalSize, LockMode::Shared};
+
+        if (mode != AccessMode::CREATE_READ_WRITE)
+        {
+            // Recover stride from mapped size: stride = mappedSize / count
+            _poolGrainStride = _pool.mappedSize() / count;
+        }
+
+        _poolGrainCount = count;
+
+        // Placement-new GrainHeader for each grain slot if creating
+        if (mode == AccessMode::CREATE_READ_WRITE)
+        {
+            auto* base = static_cast<uint8_t*>(_pool.data());
+            for (std::size_t i = 0; i < count; ++i)
+            {
+                auto* grain = reinterpret_cast<Grain*>(base + i * _poolGrainStride);
+                new (&grain->header) GrainHeader{};
+            }
+        }
+        else
+        {
+            // Verify grain version on open
+            for (std::size_t i = 0; i < count; ++i)
+            {
+                auto* grain = grainAt(i);
+                if (grain && grain->header.info.version != GRAIN_HEADER_VERSION)
+                {
+                    throw std::invalid_argument{
+                        fmt::format("Pool grain[{}]: unsupported version {}, expected {}",
+                                    i, grain->header.info.version, GRAIN_HEADER_VERSION)};
+                }
+            }
+        }
+    }
+
+    inline bool DiscreteFlowData::isPoolMode() const noexcept
+    {
+        return _poolGrainCount > 0;
+    }
+
+    inline void* DiscreteFlowData::poolBase() noexcept
+    {
+        return _pool.data();
+    }
+
+    inline void const* DiscreteFlowData::poolBase() const noexcept
+    {
+        return _pool.cdata();
+    }
+
+    inline std::size_t DiscreteFlowData::poolMappedSize() const noexcept
+    {
+        return _pool.mappedSize();
+    }
+
+    inline std::size_t DiscreteFlowData::grainStride() const noexcept
+    {
+        return _poolGrainStride;
+    }
+
     inline Grain* DiscreteFlowData::grainAt(std::size_t i) noexcept
     {
+        if (isPoolMode())
+        {
+            if (i < _poolGrainCount && _pool.data() != nullptr)
+            {
+                auto* base = static_cast<uint8_t*>(_pool.data());
+                return reinterpret_cast<Grain*>(base + i * _poolGrainStride);
+            }
+            return nullptr;
+        }
         return (i < _grains.size()) ? _grains[i].get() : nullptr;
     }
 
     inline Grain const* DiscreteFlowData::grainAt(std::size_t i) const noexcept
     {
+        if (isPoolMode())
+        {
+            if (i < _poolGrainCount && _pool.cdata() != nullptr)
+            {
+                auto const* base = static_cast<uint8_t const*>(_pool.cdata());
+                return reinterpret_cast<Grain const*>(base + i * _poolGrainStride);
+            }
+            return nullptr;
+        }
         return (i < _grains.size()) ? _grains[i].get() : nullptr;
     }
 
